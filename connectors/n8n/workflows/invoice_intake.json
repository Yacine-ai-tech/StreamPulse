{
  "name": "Invoice Intake — Gmail → DocIntel → StreamPulse",
  "nodes": [
    {
      "parameters": { "path": "invoice-intake-v2", "httpMethod": "POST", "responseMode": "lastNode", "options": {} },
      "name": "Webhook New Invoice",
      "type": "n8n-nodes-base.webhook",
      "position": [-200, 0]
    },
    {
      "parameters": {
        "url": "https://docintel.ysiddo-ai-projects.app/api/v1/extract",
        "method": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "options": {
          "headers": {
            "X-OmniIntel-Internal-Token": "omniintel-prod-internal-2026"
          }
        }
      },
      "name": "DocIntel Extract",
      "type": "n8n-nodes-base.httpRequest",
      "position": [80, 0]
    },
    {
      "parameters": {
        "url": "https://streampulse.ysiddo-ai-projects.app/ingest/json",
