  "connections": {
    "Webhook New Invoice": { "main": [[{ "node": "DocIntel Extract", "type": "main", "index": 0 }]] },
    "DocIntel Extract": { "main": [[{ "node": "StreamPulse Ingest", "type": "main", "index": 0 }]] }
  }
