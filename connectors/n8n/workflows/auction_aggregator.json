{
  "name": "Auction Aggregator → StreamPulse (with vision)",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "minutes", "minutesInterval": 15 }] }
      },
      "name": "Every 15 min",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [-200, 0]
    },
    {
      "parameters": {
        "url": "https://dummyjson.com/products",
        "options": {}
      },
      "name": "Fetch Dummy Auctions",
      "type": "n8n-nodes-base.httpRequest",
      "position": [40, 0]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.products.length > 0 }}",
              "value2": true
            }
          ]
        }
      },
      "name": "Has Products?",
      "type": "n8n-nodes-base.if",
      "position": [240, 0]
    },
    {
      "parameters": {
        "url": "https://streampulse.ysiddo-ai-projects.app/webhook/auction_aggregator/with-vision",
        "method": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({records: $json.products}) }}",
        "options": { 
          "headers": {
            "X-OmniIntel-Internal-Token": "omniintel-prod-internal-2026",
            "X-Signature-256": "={{ $credentials.streampulseHmac.signature }}" 
          } 
        }
      },
      "name": "StreamPulse",
      "type": "n8n-nodes-base.httpRequest",
      "position": [440, -100]
    }
  ],
  "connections": {
    "Every 15 min": { "main": [[{ "node": "Fetch Dummy Auctions", "type": "main", "index": 0 }]] },
    "Fetch Dummy Auctions": { "main": [[{ "node": "Has Products?", "type": "main", "index": 0 }]] },
    "Has Products?": { "main": [[{ "node": "StreamPulse", "type": "main", "index": 0 }]] }
  }
}
