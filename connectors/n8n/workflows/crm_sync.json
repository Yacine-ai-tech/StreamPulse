{
  "name": "CRM Sync — Sheets → StreamPulse",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [{ "field": "hours", "hoursInterval": 1 }] } },
      "name": "Hourly",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [-200, 0]
    },
    {
      "parameters": { "sheetName": "CRM Pipeline" },
      "name": "Read Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "position": [80, 0]
    },
    {
      "parameters": {
        "url": "http://localhost:8004/ingest/json",
        "method": "POST",
        "sendBody": true,
        "specifyBody": "json"
      },
      "name": "StreamPulse",
      "type": "n8n-nodes-base.httpRequest",
      "position": [400, 0]
    }
  ],
  "connections": {
    "Hourly": { "main": [[{ "node": "Read Sheet", "type": "main", "index": 0 }]] },
    "Read Sheet": { "main": [[{ "node": "StreamPulse", "type": "main", "index": 0 }]] }
  }
}
