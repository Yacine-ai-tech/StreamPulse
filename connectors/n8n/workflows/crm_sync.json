{
  "name": "CRM Sync — DummyJSON → StreamPulse",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [{ "field": "hours", "hoursInterval": 1 }] } },
      "name": "Hourly",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [-200, 0]
    },
    {
      "parameters": {
        "url": "https://dummyjson.com/todos",
        "options": {}
      },
      "name": "Get Dummy Tasks",
      "type": "n8n-nodes-base.httpRequest",
      "position": [40, 0]
    },
    {
      "parameters": {
        "url": "https://streampulse.ysiddo-ai-projects.app/ingest/json",
        "method": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({tasks: $json.todos}) }}",
        "options": {
          "headers": {
            "X-OmniIntel-Internal-Token": "omniintel-prod-internal-2026"
          }
        }
      },
      "name": "StreamPulse",
      "type": "n8n-nodes-base.httpRequest",
      "position": [240, 0]
    }
  ],
  "connections": {
    "Hourly": { "main": [[{ "node": "Get Dummy Tasks", "type": "main", "index": 0 }]] },
    "Get Dummy Tasks": { "main": [[{ "node": "StreamPulse", "type": "main", "index": 0 }]] }
  }
}
